{% comment %}
  Unified work/experience entry renderer for both RenderCV and JSONResume formats
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item">
      <div class="row">
        <div class="col-2 text-center" style="min-width: 120px">
          {% if entry.logo %}
            <img src="{{ entry.logo | relative_url }}" alt="{{ entry.company }} logo" style="width: 48px; height: 48px; object-fit: contain; margin-bottom: 8px; border-radius: 8px;">
          {% endif %}

          {% capture start_date %}
            {% if entry.start_date %}{{ entry.start_date }}{% elsif entry.startDate %}{{ entry.startDate }}{% endif %}
          {% endcapture %}
          {% capture end_date %}
            {% if entry.end_date %}{{ entry.end_date }}{% elsif entry.endDate %}{{ entry.endDate }}{% endif %}
          {% endcapture %}

          {% if start_date != '' %}
            {% assign startDate = start_date | split: '-' | first %}
            {% assign endDate = end_date | split: '-' | first | default: 'Present' %}
            {% assign date = startDate | append: ' - ' | append: endDate %}
          {% else %}
            {% assign date = '' %}
          {% endif %}

          <div>
            <span class="badge font-weight-bold danger-color-dark text-uppercase align-middle" style="min-width: 85px; white-space: nowrap">{{ date }}</span>
          </div>

          {% capture location %}
            {% if entry.location %}{{ entry.location }}{% endif %}
          {% endcapture %}
          {% if location != '' %}
            <p class="location mt-1" style="font-size: 0.75rem">
              <i class="fa-solid fa-location-dot iconlocation"></i>
              {{ location }}
            </p>
          {% endif %}
        </div>
        <div class="col mt-2 mt-md-0">
          {% capture company_name %}
            {% if entry.name %}{{ entry.name }}{% elsif entry.company %}{{ entry.company }}{% elsif entry.organization %}{{ entry.organization }}{% endif %}
          {% endcapture %}
          {% if entry.url %}
            <h5 class="font-weight-bold mb-0" style="font-size: 1.15rem">
              <a href="{{ entry.url }}">{{ company_name }}</a>
            </h5>
          {% elsif company_name != '' %}
            <h5 class="font-weight-bold mb-0" style="font-size: 1.15rem">{{ company_name }}</h5>
          {% endif %}

          {% capture position_title %}
            {% if entry.position %}{{ entry.position }}{% endif %}
          {% endcapture %}
          {% if position_title != '' %}
            <h6 class="mt-1" style="font-size: 0.9rem; font-weight: 400; color: var(--global-theme-color)">{{ position_title }}</h6>
          {% endif %}

          {% if entry.summary %}
            <h6 style="font-size: 0.95rem; font-style: italic">
              {{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}
            </h6>
          {% endif %}

          {% if entry.highlights %}
            <ul class="items">
              {% for item in entry.highlights %}
                <li>
                  <span class="item">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
